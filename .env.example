# GiftForge — Environment Variables
# Copy this file to .env.local and fill in your values

# PostgreSQL connection string
DATABASE_URI=postgresql://postgres:password@localhost:5432/giftforge

# Payload CMS secret (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=your-super-secret-payload-key-change-this

# Razorpay credentials (from Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Application URL (no trailing slash)
APP_URL=http://localhost:3000

# Supabase (Inventory & Stock)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
